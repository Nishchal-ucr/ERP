# Copy to .env and adjust. See README.md in this folder and repo root.

PORT=8001
DATABASE_URL=postgresql://erp_user:STRONG_PASSWORD@127.0.0.1:5432/erp_db
JWT_SECRET=your-secret-key
JWT_EXP_HOURS=24

# Optional: master CSV paths (defaults to flask-backend/csvs/*.csv when unset)
# CSV_SELLERS_PATH=
# CSV_FEED_CLOSING_PATH=
# CSV_FEED_FORMULATIONS_PATH=

# Optional: values used only when seeding a fresh DB (never commit real secrets)
# SEED_SMTP_APP_PASSWORD=
# SEED_SMTP_SENDER_EMAIL=
# SEED_SMTP_HOST=smtp.gmail.com
# SEED_SMTP_PORT=587
